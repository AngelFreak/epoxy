# Epoxy Sandbox USB Device Rules
# Install on host: sudo cp 99-usb-devices.rules /etc/udev/rules.d/ && sudo udevadm control --reload-rules

# ── Serial Adapters ─────────────────────────────────────────────────
SUBSYSTEM=="usb", ATTR{idVendor}=="0403", MODE="0666", GROUP="plugdev"  # FTDI
SUBSYSTEM=="usb", ATTR{idVendor}=="067b", MODE="0666", GROUP="plugdev"  # Prolific
SUBSYSTEM=="usb", ATTR{idVendor}=="10c4", MODE="0666", GROUP="plugdev"  # SiLabs CP210x
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", MODE="0666", GROUP="plugdev"  # CH340/CH341
SUBSYSTEM=="usb", ATTR{idVendor}=="2341", MODE="0666", GROUP="plugdev"  # Arduino

# ── Debug Probes ────────────────────────────────────────────────────
SUBSYSTEM=="usb", ATTR{idVendor}=="1366", MODE="0666", GROUP="plugdev"                           # SEGGER J-Link
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="3748", MODE="0666", GROUP="plugdev"  # ST-Link

# ── Storage ─────────────────────────────────────────────────────────
SUBSYSTEM=="usb", ATTR{idVendor}=="0781", MODE="0666", GROUP="plugdev"  # SanDisk
SUBSYSTEM=="usb", ATTR{idVendor}=="0951", MODE="0666", GROUP="plugdev"  # Kingston

# ── Generic TTY ─────────────────────────────────────────────────────
KERNEL=="ttyUSB[0-9]*", MODE="0666", GROUP="dialout"
KERNEL=="ttyACM[0-9]*", MODE="0666", GROUP="dialout"

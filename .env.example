# Epoxy Sandbox Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Authentication (one of these required) ──────────────────────────
# API key from console.anthropic.com
#ANTHROPIC_API_KEY=sk-ant-...

# OAuth token (alternative to API key)
#CLAUDE_CODE_OAUTH_TOKEN=

# ── Model ───────────────────────────────────────────────────────────
# Override default model (e.g., claude-sonnet-4-20250514)
#ANTHROPIC_MODEL=

# Custom API endpoint
#ANTHROPIC_BASE_URL=

# ── Firewall ────────────────────────────────────────────────────────
# Disable egress firewall (0=enabled, 1=disabled)
SKIP_FIREWALL=0

# Additional allowed domains (comma-separated)
#EXTRA_FW_DOMAINS=example.com,api.example.com

# ── Updates & Dependencies ──────────────────────────────────────────
# Skip Claude Code update check on boot
SKIP_UPDATE=0

# Pin to installed version (no updates)
PIN_VERSION=0

# Skip auto-dependency detection
SKIP_DEPS=0

# ── Logging ─────────────────────────────────────────────────────────
# Enable terminal logging (0=disabled, 1=enabled)
ENABLE_LOGGING=1

# ── Project ─────────────────────────────────────────────────────────
# Project name (used for snapshot directory naming)
#PROJECT_NAME=my-project

# Git repo to clone into /workspace/project on first start (if empty)
#PROJECT_REPO=https://github.com/user/repo

# ── Session ─────────────────────────────────────────────────────────
# Named session for persistence across restarts
#SESSION_NAME=my-session
